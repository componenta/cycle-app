{
    "name": "componenta/cycle-app",
    "description": "Componenta application integration for Cycle ORM discovery and console commands",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/app-console": "^1.0",
        "componenta/class-finder": "^1.0",
        "componenta/config": "^1.0",
        "componenta/cycle": "^1.0",
        "componenta/tokenizer": "^1.0",
        "cycle/annotated": "^4.4",
        "cycle/database": "^2.11",
        "cycle/migrations": "^4.2",
        "cycle/orm": "^2.11",
        "cycle/schema-builder": "^2.11",
        "psr/container": "^2.0",
        "symfony/console": "^7.4 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Cycle\\App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Cycle\\App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Cycle\\App\\ConfigProvider"
            ]
        }
    }
}
